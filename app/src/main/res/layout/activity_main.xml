<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/void_black"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RADIANT"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.15"
        android:textColor="@color/radiant_amber"
        android:textSize="24sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OFFLINE MESH"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Radar Status Visual -->
    <View
        android:id="@+id/view_radar_ring"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_input_field"
        android:backgroundTint="#1AFFFFFF"
        app:layout_constraintBottom_toTopOf="@id/card_stats"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <ImageView
        android:id="@+id/iv_status_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:tint="@color/radiant_amber"
        app:layout_constraintBottom_toBottomOf="@id/view_radar_ring"
        app:layout_constraintEnd_toEndOf="@id/view_radar_ring"
        app:layout_constraintStart_toStartOf="@id/view_radar_ring"
        app:layout_constraintTop_toTopOf="@id/view_radar_ring" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Idle"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/view_radar_ring"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Stats Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="@color/surface_grey"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/input_grey"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/btn_start_mesh">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE PEERS"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tv_peers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Actions -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_mesh"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Activate Mesh"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        app:cornerRadius="30dp"
        app:backgroundTint="@color/radiant_amber"
        app:layout_constraintBottom_toTopOf="@id/btn_chat" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_chat"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Global Channel"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        app:cornerRadius="30dp"
        app:strokeColor="@color/radiant_amber"
        app:strokeWidth="1dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>