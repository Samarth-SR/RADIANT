<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/void_black">

    <!-- Chat Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/surface_grey"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <!-- Channel Name -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="# GLOBAL"
            android:textColor="@color/radiant_amber"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textSize="18sp" />

        <!-- Clear Chat Button (Added to match Java code) -->
        <Button
            android:id="@+id/btn_clear_chat"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="CLEAR"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:backgroundTint="#CCFF0000"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />
    </LinearLayout>

    <!-- Message List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"/>

    <!-- Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@color/surface_grey">

        <EditText
            android:id="@+id/edit_message_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Broadcast message..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/white"
            android:background="@drawable/bg_input_field"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:inputType="textCapSentences"
            android:maxLines="4"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btn_send_message"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text=">"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="@color/radiant_amber"
            android:textColor="@color/void_black" />
    </LinearLayout>

</LinearLayout>